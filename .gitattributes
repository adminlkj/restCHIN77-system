# توحيد نهايات الأسطر عبر كل المنصات (Windows/Linux/macOS).
# بدون هذا الملف، تظهر اختلافات وهمية كثيرة (CRLF مقابل LF) في diff.
* text=auto eol=lf

# ملفات نصية صريحة
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.jsonc text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# ملفات Windows-native تبقى CRLF (سكريبتات batch/PowerShell)
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# ملفات ثنائية (لا تُعدّل نهايات أسطرها)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
